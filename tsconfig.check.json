{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "bun-types"],
    "paths": {
      "@/*": ["./packages/web/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/src/**/*.d.ts",
    "packages/*/tests/**/*.ts",
    "packages/*/tests/**/*.tsx",
    "packages/web/vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "**/dist"]
}
